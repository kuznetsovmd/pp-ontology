<owl:NamedIndividual rdf:about="#aa55556d4f824f3d8b48aef:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#630163a5989d45dbb2bbe60:User"/>
  <has_mechanism rdf:resource="#21fcdd45bae54e2bb9d62c9:Manual"/>
  <applies_to rdf:resource="#67461c223da14188a350254:TrackingData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">aa55556d4f824f3d8b48aef</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">You can disable and/or delete all types of cookies by using your browser settings Cookies are generally easy to disable and/or delete but how you do so varies from browser to browser The help function within your browser should tell you how to do it The best way may be to close your browser and then search for cookie folder or cookie manager or simply cookie Please also visit www allaboutcookies org for more information about cookies and how to disable them If you do disable cookies our Websites will not recognize you and you may not have access to all portions of the Websites</evidence>
</owl:NamedIndividual>

