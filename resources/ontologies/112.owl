<owl:NamedIndividual rdf:about="#9e90065c7509430f8f3f617:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#630163a5989d45dbb2bbe60:User"/>
  <has_mechanism rdf:resource="#677bd3cd95f44df7afa9683:Manual"/>
  <applies_to rdf:resource="#f79d91426ac640b391b9e1d:SensitiveData"/>
