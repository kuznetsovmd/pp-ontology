<owl:NamedIndividual rdf:about="#8726fd620c794bc18355dc8:FPCollection">
  <rdf:type rdf:resource="#FPCollection"/>
  <initiated_by rdf:resource="#d6c63ac7e526485ca915146:FirstParty"/>
  <applies_to rdf:resource="#52308abd97cb40ea9b24964:TrackingData"/>
  <collects_from rdf:resource="#630163a5989d45dbb2bbe60:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">8726fd620c794bc18355dc8</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">What are clear gifs? Clear gifs are tiny graphics with a unique identifier similar in function to cookies and are used to track the online movements of Web users In contrast to cookies which are stored on a users computer hard drive clear gifs are embedded invisibly on Web pages and are about the size of the full-stop or period at the end of this sentence</evidence>
</owl:NamedIndividual>

