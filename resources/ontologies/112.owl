<owl:NamedIndividual rdf:about="#b9d3843bbaa2416eba2c963:FPSpecific">
  <rdf:type rdf:resource="#FPSpecific"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">b9d3843bbaa2416eba2c963</uuid>
