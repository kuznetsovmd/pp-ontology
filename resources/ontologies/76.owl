  <owl:inverseOf rdf:resource="#caused_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#caused_by">
  <owl:inverseOf rdf:resource="#causes"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_consequence_of">
  <owl:inverseOf rdf:resource="#has_consequence"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_consequence">
