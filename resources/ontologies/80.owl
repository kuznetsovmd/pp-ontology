<owl:NamedIndividual rdf:about="#08a1b35f6d4a41f39450eaa:OrganizationalMeasure">
  <rdf:type rdf:resource="#OrganizationalMeasure"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">08a1b35f6d4a41f39450eaa</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Compliance and cooperation with regulatory authorities We regularly review our compliance with our Privacy Policy We also adhere to several self regulatory frameworks When we receive formal written complaints we will contact the person who made the complaint to follow up We work with the appropriate regulatory authorities including local data protection authorities to resolve any complaints regarding the transfer of personal data that we cannot resolve with our users directly</evidence>
</owl:NamedIndividual>

