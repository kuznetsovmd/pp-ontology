<owl:NamedIndividual rdf:about="#b06be965085546fba9891be:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#54bf25c054fb4409bf0925b:FirstParty"/>
  <has_mechanism rdf:resource="#cb8600dabff24f9894a1acc:PseudoAnonymization"/>
