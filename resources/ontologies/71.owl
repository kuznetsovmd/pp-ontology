<owl:NamedIndividual rdf:about="#d928db51ea8947e89d6db21:Manual">
  <rdf:type rdf:resource="#Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">d928db51ea8947e89d6db21</uuid>
