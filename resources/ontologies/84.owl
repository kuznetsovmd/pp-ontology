<owl:NamedIndividual rdf:about="#bc9bfa00b38d4a8fbeb1421:OptControl">
  <rdf:type rdf:resource="#OptControl"/>
  <initiated_by rdf:resource="#4aaaa288cffe4f88b58df71:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bc9bfa00b38d4a8fbeb1421</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do Not Track Do Not Track DNT is a privacy preference that users can set in their web browsers allowing users to opt out of tracking by websites and online services At the present time the World Wide Web Consortium W3C has not yet established universal standards for recognizable DNT signals and therefore GameStop does not recognize DNT</evidence>
</owl:NamedIndividual>

