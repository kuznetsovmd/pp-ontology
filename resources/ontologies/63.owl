<owl:NamedIndividual rdf:about="#evidence754">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A special note for parents concerning privacy The Website is a general audience Website We do not currently collect any personal information from children under the age of thirteen on the Website If in the future we collect personally identifiable information from children it will do so in compliance with the Children s Online Privacy Protection Act of 1998 15 U S C 6501 et seq including without limitation obtaining necessary parental consent For more information about the privacy practices for our affiliated children s Website NFLPlayFootball com please consult the privacy policy at the children s Website</evidenceContent>
</owl:NamedIndividual>

