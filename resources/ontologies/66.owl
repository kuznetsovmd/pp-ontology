  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">13442b23a9694c52a353464</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Your California Privacy Rights California Civil Code Section 1798 83 permits California residents to request a notice from us describing which categories of personal information we have shared with third parties or corporate affiliates for those third parties or corporate affiliates direct marketing purposes within the last calendar year and the name and address of such parties If you are a California resident and would like a copy of this notice please send an email to privacy barnesandnoble com with California Privacy Rights Request in the subject line</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#1efe3d826c9f4eedaf6e099:OptControl">
  <rdf:type rdf:resource="#OptControl"/>
  <initiated_by rdf:resource="#3d63d8e262454f5d968d8cf:User"/>
