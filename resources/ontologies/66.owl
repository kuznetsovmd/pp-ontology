<owl:NamedIndividual rdf:about="#evidence932">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9 What other information about Barnes Noble s Privacy Policy would I want to know? Policies for Minors including children under the age of 13 Barnes Noble is committed to complying with all applicable laws and regulations regarding the collection storage and use of personal information of Minors under the age of 13 including the Children s Online Privacy Protection Act of 1998</evidenceContent>
</owl:NamedIndividual>

