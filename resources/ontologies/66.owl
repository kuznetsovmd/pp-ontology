<owl:NamedIndividual rdf:about="#1725174925ef4753b511283:UserSpecialCategory">
  <rdf:type rdf:resource="#UserSpecialCategory"/>
  <is_special_category_for rdf:resource="#3d63d8e262454f5d968d8cf:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1725174925ef4753b511283</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9 What other information about Barnes Noble s Privacy Policy would I want to know? Policies for Minors including children under the age of 13 Barnes Noble is committed to complying with all applicable laws and regulations regarding the collection storage and use of personal information of Minors under the age of 13 including the Children s Online Privacy Protection Act of 1998</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#b81fbe757d2f4757a50f4ca:UserSpecialCategory">
  <rdf:type rdf:resource="#UserSpecialCategory"/>
