<owl:NamedIndividual rdf:about="#ef0ffe91bf4f44268904382:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#7f8c728ef8fe49ada13be1c:FirstParty"/>
  <has_mechanism rdf:resource="#406d670201264592be5fd56:PseudoAnonymization"/>
