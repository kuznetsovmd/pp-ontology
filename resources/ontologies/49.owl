<owl:NamedIndividual rdf:about="#8ef7265e35214c4fb61b0e5:TechnicalMeasure">
  <rdf:type rdf:resource="#TechnicalMeasure"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">8ef7265e35214c4fb61b0e5</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Data Security We have in place physical electronic and managerial procedures to protect the information we collect online However as effective as these measures are no security system is impenetrable We cannot guarantee the security of our database nor can we guarantee that the information you supply will not be intercepted while being transmitted to us over the Internet</evidence>
</owl:NamedIndividual>

