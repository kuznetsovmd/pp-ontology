  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">52f1484ab6674a0e9debde6</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">During the course of any visit to the Sci-News com website the pages you see along with a cookie are downloaded to your device A website does this because cookies enable a publisher to find out whether the device has visited the website before This is done on a repeat visit by checking to see and finding the cookie left there on the last visit</evidence>
</owl:NamedIndividual>

