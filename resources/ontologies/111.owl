<owl:NamedIndividual rdf:about="#de8c4e380d334e15be0985e:DataActivityPurpose">
  <rdf:type rdf:resource="#DataActivityPurpose"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">de8c4e380d334e15be0985e</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Upon termination of our Business Associate Agreement with a particular healthcare provider, we generally must return or destroy all protected health information received on behalf of or created for that particular healthcare provider and then maintained in any form by us or a subcontractor. I</evidence>
</owl:NamedIndividual>

