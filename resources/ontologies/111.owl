<owl:NamedIndividual rdf:about="#6ed35ed770b44b628e02f3a:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#bf6a509d0805427fbc0b152:User"/>
  <has_mechanism rdf:resource="#a7820ec0d5934c3bb0a424d:Manual"/>
