<owl:NamedIndividual rdf:about="#41a7fddca28c422e8ad62b9:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#bf6a509d0805427fbc0b152:User"/>
  <has_mechanism rdf:resource="#e6e40bb0060c45c29722aa8:Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">41a7fddca28c422e8ad62b9</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Opting Out of Requested Communications Requested communications include for instance email newsletters or software updates that may be expressly requested by you or which you consented to receive After you request such communications you may opt out of receiving them by using one of the following methods Select the email opt out or unsubscribe link or follow the opt-out instructions included in each email communication To unsubscribe from text messages delivered to mobile devices reply to the message with the words STOP or END Return to the web page s where you originally registered your preferences and follow the opt-out instructions Contact us Please provide your name contact information and specific relevant information that you no longer wish to receive</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#291ba5e804e14f29bf7485c:Manual">
