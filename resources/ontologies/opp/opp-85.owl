<owl:NamedIndividual rdf:about="#8d1c7142b13e495ba91d308:DataProtection">
  <rdf:type rdf:resource="#DataProtection"/>
  <initiated_by rdf:resource="#ca78f6b7cf154ce2af39f10:FirstParty"/>
  <has_mechanism rdf:resource="#76b1ac1944dd4cfbaf24f9d:TechnicalSecurityMeasure"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">8d1c7142b13e495ba91d308</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
