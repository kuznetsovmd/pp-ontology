<owl:NamedIndividual rdf:about="#evidence2">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Privacy and Security Commitment Our Promise to You Dallas County Community College District s DCCCD Privacy Commitment is based on two principles We promise to Comply with all the applicable local state and federal laws and regulations and Protect your privacy while still offering relevant personalized service</evidenceContent>
</owl:NamedIndividual>

