<owl:NamedIndividual rdf:about="#4435fa2c0c5746708f95d71:DataActivityPurpose">
  <rdf:type rdf:resource="#DataActivityPurpose"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4435fa2c0c5746708f95d71</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Texas Public Information Act requires disclosure of information by a public body -- unless the law specifically protects the information. Most information kept by a public body is public under the Act. The State Attorney General enforces this Act.</evidence>
</owl:NamedIndividual>

