<owl:NamedIndividual rdf:about="#b21f92e12e2a46c189c34ab:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#d043700f1a7940518ac6b39:FirstParty"/>
  <has_mechanism rdf:resource="#85d10000eb374889befb094:PseudoAnonymization"/>
  <applies_to rdf:resource="#fb9bfaa7b99444ef91d2c1f:NonSensitiveData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">b21f92e12e2a46c189c34ab</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
