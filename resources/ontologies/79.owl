<owl:NamedIndividual rdf:about="#5a8d4bd0f51f46578fc996e:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#d043700f1a7940518ac6b39:FirstParty"/>
  <has_purpose rdf:resource="#d84c63a1e1f2460bac92e5f:DataActivityPurpose"/>
  <has_mechanism rdf:resource="#d0e6f5ab41b3431ea468010:TPSaCMechanism"/>
  <applies_to rdf:resource="#44dbb631bffd4fe7987e1dc:GenericData"/>
