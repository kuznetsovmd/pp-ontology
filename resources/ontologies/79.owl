<owl:NamedIndividual rdf:about="#8e6bcd06f0a84952a0ebef7:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#d043700f1a7940518ac6b39:FirstParty"/>
  <has_purpose rdf:resource="#a808ecbf53474c62937437c:DataActivityPurpose"/>
  <has_mode rdf:resource="#947d03942cbb4813ae4395b:DataTransmissionMode"/>
  <has_mechanism rdf:resource="#fc8897ccf3fa4966891afdd:TPSaCMechanism"/>
  <collects_from rdf:resource="#b15cd81d3697445286756aa:ThirdParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">8e6bcd06f0a84952a0ebef7</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ii You have entered a contest or sweepstakes sponsored by a third party in which case the information you provide via the contest or sweepstakes may be shared by us with that third party for their use in their discretion including direct marketing Some of our contests and sweepstakes will ask you at the time of entry whether you would like to have your personal information shared with the sponsor in which case we will honor your selection Other contests will not give you that option and in that event if you do not want your information to be shared you should not enter the contest The privacy policies of such third party companies apply to their use and disclosure of your information that we collect and disclose to such third party companies</evidence>
</owl:NamedIndividual>

