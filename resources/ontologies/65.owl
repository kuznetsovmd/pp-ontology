<owl:NamedIndividual rdf:about="#3dad56e2b73647cf90480b9:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#54b00b86b11347d69931e66:FirstParty"/>
  <has_mechanism rdf:resource="#2107a27637a4467693613a5:PseudoAnonymization"/>
