<owl:NamedIndividual rdf:about="#58e251fdc4644c9ab825d98:Manual">
  <rdf:type rdf:resource="#Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">58e251fdc4644c9ab825d98</uuid>
