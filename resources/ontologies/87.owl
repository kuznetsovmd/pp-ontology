<owl:NamedIndividual rdf:about="#6202209765814f71b4c3107:FPCollection">
  <rdf:type rdf:resource="#FPCollection"/>
  <initiated_by rdf:resource="#b9a81ccd8e9f4bb4b2365c8:FirstParty"/>
  <has_purpose rdf:resource="#88d6bb53c1ce4f7eaccc47b:DataActivityPurpose"/>
