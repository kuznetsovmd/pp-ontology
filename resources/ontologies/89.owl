  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">"persistent" cookies</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#38c70045f290493896cd113:DataActivityPurpose">
  <rdf:type rdf:resource="#DataActivityPurpose"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">38c70045f290493896cd113</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">primarily to ensure that we do not show you pages that you have already seen and to personalize your site experience and save you time. "Persistent" Cookies enable us to recognize whether you have responded to any poll or seen an advertisement or information notice placed on the site so that we do not show you the poll, advertisement or notice again the next time you visit our site.</evidence>
</owl:NamedIndividual>

