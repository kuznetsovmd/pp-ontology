  <applies_to rdf:resource="#86cc7dc0eb624110b988937:NonSensitiveData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">13ad28dc31844f459b537dc</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When you create a Steam account Valve collects a user s email address and username and at the user s option first and last name Depending on their settings users agree that some of this information may be searchable and available to other users within Steam Valve has no obligation to keep private personally identifiable information that a user makes available to other users via Steam or other Valve software such as in multiplayer chat or other public functions</evidence>
</owl:NamedIndividual>

