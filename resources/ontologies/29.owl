  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">d5a8bb82d2ee42a18b83ed4</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">eb site addresses, page views and browser type</evidence>
</owl:NamedIndividual>

