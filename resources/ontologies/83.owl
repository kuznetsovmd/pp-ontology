<owl:NamedIndividual rdf:about="#44d8a95a89944afc8aa4b44:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#22afbe5d23ca4f18ae2b2a3:FirstParty"/>
  <has_mechanism rdf:resource="#5a6dfbad677d4e5e88b31c2:PseudoAnonymization"/>
  <applies_to rdf:resource="#9028b275a8c44555a84f499:GenericData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">44d8a95a89944afc8aa4b44</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HOW WE USE YOUR INFORMATION Personally identifying information that we collect for a particular promotional purpose through one of our websites or to make a purchase from the PlayStation Shop is saved and used only for that purpose unless the participant chooses to opt-in to one of our marketing programs Visitors to our websites may be given the opportunity to opt-in to two different programs The first option is to receive marketing content from SCEA The second is to have personal information shared with SCEA s third party partners so that they may send you marketing materials</evidence>
</owl:NamedIndividual>

