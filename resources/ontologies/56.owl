  <initiated_by rdf:resource="#f5fcabd2899b43eda035da0:FirstParty"/>
  <has_mechanism rdf:resource="#42ff9731f3ca4445ab2d081:TPSaCMechanism"/>
  <collects_from rdf:resource="#af648762dc1c42e4b400dd4:ThirdParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">a189fcb3f1c042d28eb5ddb</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">your private information is never for sale This means that we will only share your personal data with your consent and after letting you know what information will be shared and with whom unless it is otherwise permitted in this policy While advertisers may target their ads to the topic of a given subreddit or based on your IP address we do not sell or otherwise give access to any information collected about our users to any third party</evidence>
</owl:NamedIndividual>

