<owl:NamedIndividual rdf:about="#f8309ca9d8014b758155381:Retention">
  <rdf:type rdf:resource="#Retention"/>
  <initiated_by rdf:resource="#f5fcabd2899b43eda035da0:FirstParty"/>
  <lasts_for rdf:resource="#4bf62dd4e6464d1881300ff:DataRetentionTime"/>
  <has_purpose rdf:resource="#9991db45a88c43a28c8a597:DataActivityPurpose"/>
  <applies_to rdf:resource="#3c5ac6af274646e1ad44291:GenericData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">f8309ca9d8014b758155381</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reddit will not disclose your information unless required by law We may disclose or preserve for future disclosure your information if we believe after due consideration that doing so is reasonably necessary to comply with a law regulation or valid legal process If we are going to release your information we will do our best to provide you with notice in advance via reddit s private messaging system unless we are prohibited by court order from doing so e g an order under 18 U S C 2705 b We reserve the right to delay notice to users in cases involving the exploitation of minors and when we believe a delay is necessary to prevent imminent and serious bodily harm to a person</evidence>
</owl:NamedIndividual>

