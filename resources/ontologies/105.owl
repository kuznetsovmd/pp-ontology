<owl:NamedIndividual rdf:about="#33345fb4edd44df98e73bac:TPSaCMechanism">
  <rdf:type rdf:resource="#TPSaCMechanism"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">33345fb4edd44df98e73bac</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">These third-party vendors may connect information about pages you visit on our Sites with information about pages you visit on other websites and media channels and show you advertising based on this combined information. The advertisement may appear when you are visiting a different section of this Site or another website or media channel if the website or media channel also has a relationship with us or our vendor.</evidence>
</owl:NamedIndividual>

