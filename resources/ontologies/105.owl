<owl:NamedIndividual rdf:about="#957ff7288fac4603bad8141:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#8a43a6d18f264e2fa8e9c87:FirstParty"/>
  <has_mechanism rdf:resource="#069d616c69664b4387f81c0:PseudoAnonymization"/>
  <applies_to rdf:resource="#f7c910745def4621ae04af4:TrackingData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">957ff7288fac4603bad8141</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3 Cookies and Targeted Advertising A Cookies Web Beacons and IP Address Information Cookies are small pieces of information that a website places on your browser when you visit that website We may use cookies to provide you with a more personal and interactive experience with the Sites and Services For example we may use cookies to control what advertisements you see the sequence of advertisements and to make sure you don t see the same advertisement too many times For contests or sweepstakes we may also use cookies in order to track your progress and the number of entries in some promotions For polls we may use cookies to help ensure that an individual can t vote more than once on a particular question or issue We do not store Personal Information in any cookies on your computer</evidence>
</owl:NamedIndividual>

