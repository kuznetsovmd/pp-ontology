<owl:NamedIndividual rdf:about="#evidence434">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">You should exercise discretion with respect to the submission of any personal or financial information via e-mail If you are concerned about the security of your communication we encourage you to send your correspondence through the postal service or use the telephone to speak directly to us We are not responsible for the security or confidentiality of communications you send to us through the Internet using e-mail messages</evidenceContent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#activity15">
  <rdf:type rdf:resource="#Activity"/>
  <hasMechanism rdf:resource="#securitymechanism4"/>
