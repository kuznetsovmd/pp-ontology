<owl:NamedIndividual rdf:about="#df9d5c61dfad44b5a0546e6:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#735abedd71104a0c8689a08:FirstParty"/>
  <has_mechanism rdf:resource="#7e4d8c7d10da4c0180ca944:PseudoAnonymization"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">df9d5c61dfad44b5a0546e6</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">We or our third party marketing partners such as Google Analytics and Adobe Analytics use cookies analytics remarketing and other technology to help us provide users with a better service and a more customized web experience Additionally our business partners use tracking services analytics and other technologies to monitor visits to allstate com The website may also use web beacons also called clear GIFs or pixel tags in conjunction with cookies If you prefer you can choose to not accept cookies by changing the settings on your web browser Many commercial Internet sites use cookies a cookie enables the site to label you as a particular user but it does not identify you by name or address unless you have provided us with such information over the Internet or otherwise or set up preferences in your browser to do so automatically</evidence>
</owl:NamedIndividual>

