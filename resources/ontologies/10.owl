</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#a26de4fb8eed4666bca5e7b:SecurityMechanism">
  <rdf:type rdf:resource="#SecurityMechanism"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">a26de4fb8eed4666bca5e7b</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">You should exercise discretion with respect to the submission of any personal or financial information via e-mail If you are concerned about the security of your communication we encourage you to send your correspondence through the postal service or use the telephone to speak directly to us We are not responsible for the security or confidentiality of communications you send to us through the Internet using e-mail messages</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#3587c58f13e646c18276227:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#735abedd71104a0c8689a08:FirstParty"/>
  <has_mechanism rdf:resource="#a26de4fb8eed4666bca5e7b:SecurityMechanism"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3587c58f13e646c18276227</uuid>
