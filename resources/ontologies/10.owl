<owl:NamedIndividual rdf:about="#7fdef467a0b147079f05b83:SecurityMechanism">
  <rdf:type rdf:resource="#SecurityMechanism"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">7fdef467a0b147079f05b83</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">E-mail messages are not secure Our security software does not encrypt e-mail messages E-mail messages traveling through the Internet are subject to viewing alteration and copying by potentially anyone on the Internet</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#b306eaca0b0841bca21cb49:Protection">
  <rdf:type rdf:resource="#Protection"/>
