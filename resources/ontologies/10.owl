  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">a07d17d00f5e4f229886500</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Social Media Widgets Our Web site includes Social Media Features such as the Facebook Like button and Widgets such as the Share this button or interactive mini-programs that run on our site These Features may collect your IP address which page you are visiting on our site and may set a cookie to enable the Feature to function properly Social Media Features and Widgets are either hosted by a third party or hosted directly on our Site Your interactions with these Features are governed by the privacy policy of the company providing it</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#1631539684274b139e136de:AccountData">
