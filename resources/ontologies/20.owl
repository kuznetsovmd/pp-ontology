<owl:NamedIndividual rdf:about="#af73afc7231140feaf3050b:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#1c716d1406d847b88d3bb9a:User"/>
  <has_mechanism rdf:resource="#9cff01dae602436fbb6fe22:Manual"/>
  <applies_to rdf:resource="#73baf555428d4faca467183:TrackingData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">af73afc7231140feaf3050b</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">You can refuse to accept these cookies and most devices and browsers offer their own privacy settings for cookies You will need to manage your cookie settings for each device and browser you use However if you do not accept these cookies you may experience some inconvenience in your use of the Site and some online products and services For example we will not be able to recognize your device and you will need to answer a challenge question each time you log on You also may not receive tailored advertising or other offers from us that may be relevant to your interests and needs</evidence>
</owl:NamedIndividual>

