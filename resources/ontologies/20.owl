    <rdf:Description rdf:about="#Consequence"/>
    <rdf:Description rdf:about="#TimePeriod"/>
    <rdf:Description rdf:about="#PolicyChangeScope"/>
    <rdf:Description rdf:about="#UserSpecialCategory"/>
  </owl:members>
</owl:AllDisjointClasses>


</rdf:RDF>
