  <has_mechanism rdf:resource="#2184bd2cab874e088973012:TechnicalMeasure"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">f8a01b9c35cb4dcf8facfa5</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Austin Community College ACC is committed to ensuring the privacy of personal information We do not actively share personal information gathered from our Web servers However because ACC is a public institution some information collected from the ACC web site including summary server log information emails and information collected from Web-based forms may be subject to This means that while we do not share or sell information unless solicited in some cases we may be compelled by Open Records law to release information</evidence>
</owl:NamedIndividual>

