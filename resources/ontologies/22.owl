<owl:NamedIndividual rdf:about="#1708706071e540168df66a5:FPCollection">
  <rdf:type rdf:resource="#FPCollection"/>
  <initiated_by rdf:resource="#db9a1f0fb8634575a3429db:FirstParty"/>
  <has_mode rdf:resource="#858d35a111c948d1a195973:DataTransmissionMode"/>
  <applies_to rdf:resource="#504de5f22dbb46bb8cd17eb:NonSensitiveData"/>
  <collects_from rdf:resource="#d642d7daf91446619da48b4:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1708706071e540168df66a5</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cookies To enhance your experience on our Services we may place cookies on your computer or device Cookies are small text files that we place in your computer or device to store your preferences Cookies by themselves do not tell us your e-mail address or other personal information unless you choose to provide this information to us by for example registering with one of our Services Once you choose to provide us with personal information this information may be linked to the data stored in the cookie A cookie assigns a unique numerical identifier to your Web browser or device and may enable us to recognize you as the same user who has used our Services and relate your use of the Services to other information about you such as your usage information and personal information</evidence>
</owl:NamedIndividual>

