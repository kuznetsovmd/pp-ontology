<owl:NamedIndividual rdf:about="#4986043c42ee47bfa4ba6d2:OptControl">
  <rdf:type rdf:resource="#OptControl"/>
  <initiated_by rdf:resource="#ed8941d815ac429892c58fc:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4986043c42ee47bfa4ba6d2</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DO NOT TRACK MNG currently does not support Do Not Track browser settings and does not currently participate in any Do Not Track frameworks that would allow us to respond to signals or other mechanism from you regarding the collection of information including PIN or CIN As Industry standards evolve and develop we will continue to evaluate this position As previously stated in the INFORMATION COLLECTED section above other parties particularly third party advertising networks also collect information</evidence>
</owl:NamedIndividual>

