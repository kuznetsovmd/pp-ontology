  <has_mechanism rdf:resource="#c6abf98b9b7a4190a8751a8:PseudoAnonymization"/>
  <applies_to rdf:resource="#460dbcf2cb494f7a974c9ea:NonSensitiveData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3d6341d634c34b078dabe1c</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">INFORMATION COLLECTED Personally Identifying Information PIN The Personally Identifying Information PIN gathered by MediaNews on MediaNews Web sites generally includes e-mail address password zip code age gender and whether you are a print subscriber but may also include your name and/or company name street address and date of birth phone numbers and credit card numbers or other billing information where necessary to contact you or to process your Web site purchases MediaNews may also collect information such as household income job title personal interests and hobbies The PIN collected depends on the page you are visiting and the services that you participate in</evidence>
</owl:NamedIndividual>

