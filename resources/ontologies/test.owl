<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://privacy-ontology.com/test.owl"
         xmlns="http://privacy-ontology.com/test.owl#">

<owl:Ontology rdf:about="http://privacy-ontology.com/test.owl"/>

<owl:ObjectProperty rdf:about="#considered_by">
  <owl:inverseOf rdf:resource="#considers"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#considers">
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Agent"/>
        <rdf:Description rdf:about="#Activity"/>
        <rdf:Description rdf:about="#Data"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <owl:inverseOf rdf:resource="#considered_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#data_considered_by">
  <rdfs:subPropertyOf rdf:resource="#considered_by"/>
  <owl:inverseOf rdf:resource="#considers_data"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#considers_data">
  <rdfs:subPropertyOf rdf:resource="#considers"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="#Data"/>
  <owl:inverseOf rdf:resource="#data_considered_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#activity_considered_by">
  <rdfs:subPropertyOf rdf:resource="#considered_by"/>
  <owl:inverseOf rdf:resource="#considers_activity"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#considers_activity">
  <rdfs:subPropertyOf rdf:resource="#considers"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="#Activity"/>
  <owl:inverseOf rdf:resource="#activity_considered_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#agent_considered_by">
  <rdfs:subPropertyOf rdf:resource="#considered_by"/>
  <owl:inverseOf rdf:resource="#considers_agent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#considers_agent">
  <rdfs:subPropertyOf rdf:resource="#considers"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="#Agent"/>
  <owl:inverseOf rdf:resource="#agent_considered_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#applied_by">
  <owl:inverseOf rdf:resource="#applies_to"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#applies_to">
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#Data"/>
  <owl:inverseOf rdf:resource="#applied_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#provided_by">
  <owl:inverseOf rdf:resource="#provides"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#provides">
  <rdfs:domain rdf:resource="#Agent"/>
  <rdfs:range rdf:resource="#Data"/>
  <owl:inverseOf rdf:resource="#provided_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#initiated_by">
  <owl:inverseOf rdf:resource="#initiates"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#initiates">
  <rdfs:domain rdf:resource="#Agent"/>
  <rdfs:range rdf:resource="#Activity"/>
  <owl:inverseOf rdf:resource="#initiated_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#notification_initiated_by">
  <rdfs:subPropertyOf rdf:resource="#initiated_by"/>
  <owl:inverseOf rdf:resource="#initiates_notification"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#initiates_notification">
  <rdfs:subPropertyOf rdf:resource="#initiates"/>
  <rdfs:domain rdf:resource="#Agent"/>
  <rdfs:range rdf:resource="#Notification"/>
  <owl:inverseOf rdf:resource="#notification_initiated_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#fp_notification_initiated_by">
  <rdfs:subPropertyOf rdf:resource="#notification_initiated_by"/>
  <owl:inverseOf rdf:resource="#initiates_fp_notification"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#initiates_fp_notification">
  <rdfs:subPropertyOf rdf:resource="#initiates_notification"/>
  <rdfs:domain rdf:resource="#FirstParty"/>
  <rdfs:range rdf:resource="#FPNotification"/>
  <owl:inverseOf rdf:resource="#fp_notification_initiated_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#user_notification_initiated_by">
  <rdfs:subPropertyOf rdf:resource="#notification_initiated_by"/>
  <owl:inverseOf rdf:resource="#initiates_user_notification"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#initiates_user_notification">
  <rdfs:subPropertyOf rdf:resource="#initiates_notification"/>
  <rdfs:domain rdf:resource="#User"/>
  <rdfs:range rdf:resource="#UserNotification"/>
  <owl:inverseOf rdf:resource="#user_notification_initiated_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#mechanism_of">
  <owl:inverseOf rdf:resource="#has_mechanism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_mechanism">
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#Mechanism"/>
  <owl:inverseOf rdf:resource="#mechanism_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#retention_mechanism_of">
  <rdfs:subPropertyOf rdf:resource="#mechanism_of"/>
  <owl:inverseOf rdf:resource="#has_retention_mechanism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_retention_mechanism">
  <rdfs:subPropertyOf rdf:resource="#has_mechanism"/>
  <rdfs:domain rdf:resource="#Retention"/>
  <rdfs:range rdf:resource="#DataRetentionMechanism"/>
  <owl:inverseOf rdf:resource="#retention_mechanism_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#communication_mechanism_of">
  <rdfs:subPropertyOf rdf:resource="#mechanism_of"/>
  <owl:inverseOf rdf:resource="#has_communication_mechanism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_communication_mechanism">
  <rdfs:subPropertyOf rdf:resource="#has_mechanism"/>
  <rdfs:domain rdf:resource="#Notification"/>
  <rdfs:range rdf:resource="#CommunicationMechanism"/>
  <owl:inverseOf rdf:resource="#communication_mechanism_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#fp_notification_mechanism_of">
  <rdfs:subPropertyOf rdf:resource="#communication_mechanism_of"/>
  <owl:inverseOf rdf:resource="#has_fp_notification_mechanism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_fp_notification_mechanism">
  <rdfs:subPropertyOf rdf:resource="#has_communication_mechanism"/>
  <rdfs:domain rdf:resource="#FPNotification"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#FPSpecific"/>
        <rdf:Description rdf:about="#Mutual"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <owl:inverseOf rdf:resource="#fp_notification_mechanism_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#user_notification_mechanism_of">
  <rdfs:subPropertyOf rdf:resource="#communication_mechanism_of"/>
  <owl:inverseOf rdf:resource="#has_user_notification_mechanism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_user_notification_mechanism">
  <rdfs:subPropertyOf rdf:resource="#has_communication_mechanism"/>
  <rdfs:domain rdf:resource="#UserNotification"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#UserSpecific"/>
        <rdf:Description rdf:about="#Mutual"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <owl:inverseOf rdf:resource="#user_notification_mechanism_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#data_control_mechanism_of">
  <rdfs:subPropertyOf rdf:resource="#mechanism_of"/>
  <owl:inverseOf rdf:resource="#has_data_control_mechanism"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_data_control_mechanism">
  <rdfs:subPropertyOf rdf:resource="#has_mechanism"/>
  <rdfs:domain rdf:resource="#DataControl"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Mutual"/>
        <rdf:Description rdf:about="#Manual"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <owl:inverseOf rdf:resource="#data_control_mechanism_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_mode_for">
  <owl:inverseOf rdf:resource="#has_mode"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_mode">
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#Mode"/>
  <owl:inverseOf rdf:resource="#is_mode_for"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_last_of">
  <owl:inverseOf rdf:resource="#lasts_for"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#lasts_for">
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#TimePeriod"/>
  <owl:inverseOf rdf:resource="#is_last_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#causes">
  <rdfs:domain rdf:resource="#Cause"/>
  <rdfs:range rdf:resource="#Activity"/>
  <owl:inverseOf rdf:resource="#caused_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#caused_by">
  <owl:inverseOf rdf:resource="#causes"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_consequence_of">
  <owl:inverseOf rdf:resource="#has_consequence"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_consequence">
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#Consequence"/>
  <owl:inverseOf rdf:resource="#is_consequence_of"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_purpose_for">
  <owl:inverseOf rdf:resource="#has_purpose"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_purpose">
  <rdfs:domain rdf:resource="#DataActivity"/>
  <rdfs:range rdf:resource="#Purpose"/>
  <owl:inverseOf rdf:resource="#is_purpose_for"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_basis_for">
  <owl:inverseOf rdf:resource="#has_basis"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_basis">
  <rdfs:domain rdf:resource="#DataActivity"/>
  <rdfs:range rdf:resource="#Basis"/>
  <owl:inverseOf rdf:resource="#is_basis_for"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#following_activity">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <owl:inverseOf rdf:resource="#followed_by_activity"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#followed_by_activity">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#Activity"/>
  <owl:inverseOf rdf:resource="#following_activity"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#next_activity_is">
  <rdfs:subPropertyOf rdf:resource="#followed_by_activity"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <owl:inverseOf rdf:resource="#previous_activity_is"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#previous_activity_is">
  <rdfs:subPropertyOf rdf:resource="#following_activity"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <owl:inverseOf rdf:resource="#next_activity_is"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#binded_to_activity">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#Activity"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#uuid">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#evidence">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing"/>
        <owl:Class>
          <owl:complementOf rdf:resource="#PrivacyPolicy"/>
        </owl:Class>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#policyId">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#policyUpdate">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#policyWebsite">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#does">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#PrivacyPolicy">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Activity">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#DataActivity">
