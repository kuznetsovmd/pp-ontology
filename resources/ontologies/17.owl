<owl:NamedIndividual rdf:about="#9c145512058d4f2c95ee128:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#6ebba98f88854be196e1550:FirstParty"/>
  <has_purpose rdf:resource="#585a4cdd6c224a07a460998:DataActivityPurpose"/>
  <has_mechanism rdf:resource="#c92ff9d7e641403c9d6b3e9:TPSaCMechanism"/>
  <applies_to rdf:resource="#be30e9679f0942ee8f00429:NonSensitiveData"/>
  <collects_from rdf:resource="#e65193e216fb48f58b5dde2:ThirdParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9c145512058d4f2c95ee128</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If you sign up for a special offer from an advertiser for example in our What Every Fool Needs or Special Offers areas or whatever we call them if we change their names we will provide your individual contact information for example name mailing address email address and/or telephone number so that the advertiser or its agent can fulfill the special offer Once the advertiser receives the information it will handle the information under its own privacy policies Obviously if you do not want a particular advertiser to have your personal information then you should not sign up for that advertiser s offer</evidence>
</owl:NamedIndividual>

