<owl:NamedIndividual rdf:about="#09b8bed6ff5b4e2c9dddb2a:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#6ebba98f88854be196e1550:FirstParty"/>
  <has_purpose rdf:resource="#fc2691afef624960bd6c584:DataActivityPurpose"/>
  <has_mechanism rdf:resource="#fb170cf3778a45c292e6112:TPSaCMechanism"/>
  <applies_to rdf:resource="#dc471e29a3084f77ae8ea45:NonSensitiveData"/>
