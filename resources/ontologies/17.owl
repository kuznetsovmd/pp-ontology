<owl:NamedIndividual rdf:about="#02f0de132b3f4c959b6d191:Data">
  <rdf:type rdf:resource="#Data"/>
  <provided_by rdf:resource="#33750d8c24d849109fffed0:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">02f0de132b3f4c959b6d191</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">we might tell an advertiser that there are 120,000 Registered Fools in Gotham City, but we will not tell them that Batman is one of them, nor will we tell them that his email address is bruce@statelywaynemanor.com. We may also use this aggregated information</evidence>
</owl:NamedIndividual>

