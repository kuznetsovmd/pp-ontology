<owl:NamedIndividual rdf:about="#d32e964daba34b7aa065517:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#6ebba98f88854be196e1550:FirstParty"/>
  <has_purpose rdf:resource="#2c5a8911fca74c99891940d:DataActivityPurpose"/>
