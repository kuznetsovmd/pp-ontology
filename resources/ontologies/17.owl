</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#evidence506">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">give, rent, lend, or sell</evidenceContent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#datacollectionmechanism104">
