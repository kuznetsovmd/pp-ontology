<owl:NamedIndividual rdf:about="#bf5e3f1068244324bb7ec35:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#6ebba98f88854be196e1550:FirstParty"/>
  <has_purpose rdf:resource="#7020cafcfd5749a48725140:DataActivityPurpose"/>
  <has_mechanism rdf:resource="#9dc8e9df868d40c098c1a34:TPSaCMechanism"/>
  <applies_to rdf:resource="#54056341def541ab877e9de:GenericData"/>
  <collects_from rdf:resource="#e65193e216fb48f58b5dde2:ThirdParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bf5e3f1068244324bb7ec35</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If you buy something from us we will disclose your personal information to the extent necessary to fulfill your order and charge your credit card if applicable We may use a fulfillment company to fill and ship your order excluding products you download directly from our site and a credit card processing company to verify your card number and process the transaction For example if you order a Fool cap with your credit card we need to give your address to the fulfillment house so that it can ship the cap to you and your credit card information to the processing company to confirm payment We may also give your information to a delivery or postal service so that it can get your order to you</evidence>
</owl:NamedIndividual>

