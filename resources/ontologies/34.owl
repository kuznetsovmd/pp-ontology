<owl:NamedIndividual rdf:about="#01e945eaefe742758e54755:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#369ebc1e9f544fe3bd98829:FirstParty"/>
  <has_mechanism rdf:resource="#8893a543d09b4040a33eba2:PseudoAnonymization"/>
  <applies_to rdf:resource="#c8e695b1ce6149e8abe5158:AccountData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">01e945eaefe742758e54755</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">We may share some anonymized search query data with selected third parties for research purposes When you click on a link from a Bing search results page the destination website will receive the standard information your browser sends to every web site you visit including the URL of the site you came from Because the URL of the Bing search results page contains the text of the search query you entered the destination website will be able to determine the search term you entered</evidence>
</owl:NamedIndividual>

