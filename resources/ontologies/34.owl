<owl:NamedIndividual rdf:about="#58c30443c8454b248b16768:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#369ebc1e9f544fe3bd98829:FirstParty"/>
  <has_purpose rdf:resource="#f825943a559148a9b5d080c:DataActivityPurpose"/>
  <collects_from rdf:resource="#76ee4aa9cb5840abb7ebe5b:ThirdParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">58c30443c8454b248b16768</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Microsoft Services Powered by Bing Microsoft services and apps that are powered by Bing services such as MSN and Bing apps Cortana and Microsoft mapping services use Bing search to provide you with enhanced features and convenient ways to access information such as weather forecasts traffic reports or internet search results not all Microsoft applications or Bing features are available in every country These Bing-powered services are available on a variety of platforms including apps preinstalled with Windows apps created for the iOS apps in the Microsoft Store and as browser plug-ins and toolbars</evidence>
</owl:NamedIndividual>

