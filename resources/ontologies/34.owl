<owl:NamedIndividual rdf:about="#eaaab47df8db42b9a4358a2:AccountData">
  <rdf:type rdf:resource="#AccountData"/>
  <provided_by rdf:resource="#664e9ae593d844eba0e4f58:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">eaaab47df8db42b9a4358a2</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">For Bing Search in your browser using the search terms you enter and the results you click search history provides an easy way to revisit the sites and searches you ve used before You may clear your search history from appearing on the site by following the steps provided here or by going to the Bing preferences page noted above Clearing your history removes it from the Search History service and prevents that history from being displayed on the site but does not delete information from our standard search logs which are retained and anonymized as described in the Collecting Your Information Section</evidence>
</owl:NamedIndividual>

