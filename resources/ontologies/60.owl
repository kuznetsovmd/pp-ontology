  <rdf:type rdf:resource="#DataActivityPurpose"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">f584f1d86f6b48d5bc61032</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">We use this information to determine our users' preferences, to design initiatives to meet those preferences, to eliminate hassles, and to generally make your TGI Fridays experience more satisfying</evidence>
