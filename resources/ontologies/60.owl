<owl:NamedIndividual rdf:about="#889731e5405b40b38c50df2:FPCollection">
  <rdf:type rdf:resource="#FPCollection"/>
  <initiated_by rdf:resource="#1fd94bb0155c44ae890bb7a:FirstParty"/>
  <has_purpose rdf:resource="#f584f1d86f6b48d5bc61032:DataActivityPurpose"/>
  <has_mechanism rdf:resource="#e57286ad35bc4e1bbca5049:UserSpecific"/>
  <collects_from rdf:resource="#7f617c441fb8411bb35db87:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">889731e5405b40b38c50df2</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When you use our digital or mobile application certain information about your activity is collected We use this information to determine our users preferences to design initiatives to meet those preferences to eliminate hassles and to generally make your TGI Fridays experience more satisfying From time to time we may initiate a program service or survey that requests your name birthday email address city of residence ZIP code or information about what you like and do not like about TGI Fridays We recognize that the loyalty of our customers depends upon our relationships with them and we strongly support the rights of customers to maintain privacy of personal data Don t worry at TGI Fridays your personal information is safe</evidence>
</owl:NamedIndividual>

