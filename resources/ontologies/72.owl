<owl:NamedIndividual rdf:about="#e3a83ccb93774a739a98443:TrackingData">
  <rdf:type rdf:resource="#TrackingData"/>
  <provided_by rdf:resource="#86c16caeab0e4382a3204f8:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">e3a83ccb93774a739a98443</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cookies" are small bits of text that are either used for the duration of a session ("session cookies"), or saved on a user's hard drive in order to identify that user, or information about that user, the next time the user logs on to a website ("persistent cookies").</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#e905cbeadea346b3991febe:DataActivityPurpose">
  <rdf:type rdf:resource="#DataActivityPurpose"/>
