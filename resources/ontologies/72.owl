<owl:NamedIndividual rdf:about="#3435c78a314f4d799a95cef:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#8e185b080b2c49a18f3f76a:FirstParty"/>
  <has_mechanism rdf:resource="#fd3663065ccb4efc924e38d:PseudoAnonymization"/>
