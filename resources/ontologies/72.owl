  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">By default, we use cookies to enable more streamlined navigation and for statistical analysis to make improvements to our website.</evidenceContent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#dataactivitypurpose33">
  <rdf:type rdf:resource="#DataActivityPurpose"/>
