  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">55375b57011f43ab84d7626</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Local storage files can be cleared through your browser settings or disabled, similar to cookies.</evidence>
</owl:NamedIndividual>

