</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#4457eab363e944e5be92110:Use">
  <rdf:type rdf:resource="#Use"/>
  <initiated_by rdf:resource="#8e185b080b2c49a18f3f76a:FirstParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4457eab363e944e5be92110</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Some of our websites such as Founder s Online use a feature called Web Storage which includes HTML5 local storage so users can retrieve searches or user-defined preferences or data marked as a favorite This feature creates a storage file on the user s local hard drive that holds links to the resources from the website that the individual user previously searched or identified as a preference or favorite No information from this file is transferred to NARA or any other website Local storage files can be cleared through your browser settings or disabled similar to cookies</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#55375b57011f43ab84d7626:Manual">
