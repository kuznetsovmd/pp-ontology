<owl:NamedIndividual rdf:about="#491d434cd52c46e2bbca3d5:TechnicalMeasure">
  <rdf:type rdf:resource="#TechnicalMeasure"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">491d434cd52c46e2bbca3d5</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The National Archives does not collect personally identifiable information through these social media platforms as outlined in Privacy Impact Assessments When a visitor shares PII such as a Social Security number we will to the extent of our ability remove the PII from the third party website in accordance with our comment and posting policies The removed information will be retained and disposed of in accordance with the applicable records schedule Access to this information is restricted to NARA employees who manage NARA s presence on third party sites or who need access to the information to carry out their official duties The information is secured as outlined in NARA s internal management policy on the handling of personally identifiable information</evidence>
</owl:NamedIndividual>

