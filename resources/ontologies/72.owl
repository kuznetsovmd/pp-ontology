<owl:NamedIndividual rdf:about="#cf1ad61a9d004632b4e8e3b:Retention">
  <rdf:type rdf:resource="#Retention"/>
  <initiated_by rdf:resource="#8e185b080b2c49a18f3f76a:FirstParty"/>
  <lasts_for rdf:resource="#14b64747d2784dfe99c052a:DataRetentionTime"/>
  <has_purpose rdf:resource="#7a4f6457e03c49938adb2db:DataActivityPurpose"/>
