  <initiated_by rdf:resource="#b0184e27606b4d92804e8eb:FirstParty"/>
  <has_mechanism rdf:resource="#b4d0c7810a964e85a7ff14e:SecurityMechanism"/>
  <has_purpose rdf:resource="#e64a6111d8ec4b2487e65f1:SecurityPurpose"/>
  <applies_to rdf:resource="#62e1cf73f21a4a45b3e2f3f:Data"/>
  <has_mechanism rdf:resource="#afb33750bf844eb7b8edd7f:TechnicalSecurityMeasure"/>
  <has_mechanism rdf:resource="#675a8d206a234a78a1d946f:Encryption"/>
  <has_mechanism rdf:resource="#a724f62ab43d4e909190aed:TechnicalSecurityMeasure"/>
  <has_mechanism rdf:resource="#fae0d70cda8c42a98b71ccd:Firewall"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">5b66b7d4ed4e4b6085bd557</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Администрация Cайта принимает все меры для защиты данных пользователей от несанкционированного доступа, в частности:


{number list}.


{list item} регулярное обновление служб и систем управления сайтом и его содержимым;


{list item} шифровка архивных копий ресурса;


{list item} регулярные проверки на предмет наличия вредоносных кодов;


{list item} использование для размещения сайта виртуального выделенного сервера.</evidence>
</owl:NamedIndividual>

