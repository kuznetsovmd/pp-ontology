  <applies_to rdf:resource="#b84622ca0ce849a3b542ee1:Data"/>
  <initiated_by rdf:resource="#c8cebceb6afe411a9673674:FirstParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9353c36a3972422b9d26b25</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Настоящая Политика конфиденциальности персональной информации (далее Политика) действует в отношении всей информации, которую интернет-портал {removed hyperref} (далее - Портал), представители Администрации Портала могут получить о пользователе во время использования им портала и (или) отдельных его страниц и функциональных сервисов.</evidence>
</owl:NamedIndividual>

