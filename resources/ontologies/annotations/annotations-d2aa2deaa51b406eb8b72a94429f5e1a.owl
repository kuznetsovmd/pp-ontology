<owl:NamedIndividual rdf:about="#9353c36a3972422b9d26b25:FPCollection">
  <rdf:type rdf:resource="#FPCollection"/>
  <collects_from rdf:resource="#5c5a44e458a648788c960a3:User"/>
  <has_mechanism rdf:resource="#6dcc526dc2914024b46b5a1:ViaWebsite"/>
  <has_mechanism rdf:resource="#f72ad6de209a4175a6a0b52:ViaWebsite"/>
  <has_mechanism rdf:resource="#585d103e017948e18376f3c:ViaServiceApp"/>
