<owl:NamedIndividual rdf:about="#dbfc7908ac8d41f5bda6f8c:TPSharing">
  <rdf:type rdf:resource="#TPSharing"/>
  <previous_is rdf:resource="#65a533bf1c204fe88072b9a:Data"/>
  <initiated_by rdf:resource="#3de8f859cb22469ca464791:FirstParty"/>
  <applies_to rdf:resource="#2688facdbd414a309fd758d:PersonalData"/>
  <initiated_by rdf:resource="#763ca92d4972407580c2de7:FirstParty"/>
  <applies_to rdf:resource="#5b966f1fe8364c5c9f4b4f5:PersonalData"/>
  <applies_to rdf:resource="#18319ec57e104887a7a131b:PersonalData"/>
