<owl:NamedIndividual rdf:about="#c232838cd1e34e0889747d5:FPCollection">
  <rdf:type rdf:resource="#FPCollection"/>
  <initiated_by rdf:resource="#d2c15df8ace94108af5bc3c:FirstParty"/>
  <has_purpose rdf:resource="#a339e35d358f4b0aa781ec5:DataActivityPurpose"/>
  <has_mechanism rdf:resource="#4c989a4405d942ed9c8d2de:UserSpecific"/>
  <applies_to rdf:resource="#b1439a67c6d84512b83ffe7:TrackingData"/>
  <collects_from rdf:resource="#50b3189a2ce54adb8ea1633:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">c232838cd1e34e0889747d5</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A transient memory-resident cookie may be invoked in certain cases For example on the CASSIDI site a cookie is required to remember your selections as you move from page to page and enable CASSIDI s functionality If you register for a Research user account a cookie will be invoked when you login to your user account These cookies will disappear when your browser is closed If you check the Stay logged in option the cookie will persist for a maximum of 2 weeks before another login is required You are not required to register for a user account to use this site</evidence>
</owl:NamedIndividual>

