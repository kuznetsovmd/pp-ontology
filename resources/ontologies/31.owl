<owl:NamedIndividual rdf:about="#efd0f0c8eb1e46cfacdd2c9:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#168a5ab4281f4fb4be599c4:FirstParty"/>
  <has_mechanism rdf:resource="#74b5a5b5293b4d939bc1a6d:TPSaCMechanism"/>
  <applies_to rdf:resource="#cc5a821d50304792ac83ea5:TrackingData"/>
