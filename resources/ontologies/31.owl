  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1c3a2b655baa4120835d4cf</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Children s Privacy JibJab is committed to protecting the privacy needs of children and we encourage parents and guardians to take an active role in their children s online activities and interests The JibJab Sites and JibJab Service are not intended for use by children under the age of 13 without parental supervision JibJab does not knowingly collect personal information from children under the age of 13 Users must be 13 or older to be eligible to register on the JibJab Sites</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#8d09813b98444fc58bf8df9:UserSpecialCategory">
  <rdf:type rdf:resource="#UserSpecialCategory"/>
  <is_special_category_for rdf:resource="#8e8ac232cad34f5f994b4ea:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">8d09813b98444fc58bf8df9</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Some of the JibJab Sites and JibJab Services such as StoryBots com are designed for parents and their young children Children can only access and use such sites and services with the participation and supervision of their parents Because of the young age of our children users only parents are allowed to create accounts and profiles and to upload personal content on such sites and services JibJab does not knowingly collect any personal information directly from children on such sites and services We also take certain measures to prevent children from submitting personal information to us or from accessing features that may collect or publish such information</evidence>
</owl:NamedIndividual>

