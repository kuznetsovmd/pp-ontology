<owl:NamedIndividual rdf:about="#7e741471182e4069a362750:TechnicalMeasure">
  <rdf:type rdf:resource="#TechnicalMeasure"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">7e741471182e4069a362750</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">We urge you to keep your username password and other account access information in a safe place and not to divulge it to anyone Also remember to sign off your account and close your browser window when you have finished your visit to a JibJab Site This is to ensure that others cannot access your account especially if you are sharing a computer with someone else or are using a computer in a public place such as a library or an internet cafe</evidence>
</owl:NamedIndividual>

