<owl:NamedIndividual rdf:about="#aebef689b587465598a5593:DataActivityPurpose">
  <rdf:type rdf:resource="#DataActivityPurpose"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">aebef689b587465598a5593</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">To tailor advertising efforts. Most of the information and services available to you at Tulsaworld.com are free. In order to continue providing services free of charge, Tulsaworld.com sells advertising. Advertisers prefer to target their communication toward audiences who are most likely to be interested in their products.</evidence>
</owl:NamedIndividual>

