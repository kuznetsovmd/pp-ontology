<owl:NamedIndividual rdf:about="#4184a6710c9d412ca82bc16:Use">
  <rdf:type rdf:resource="#Use"/>
  <initiated_by rdf:resource="#a068d057702543cebf74316:FirstParty"/>
  <has_purpose rdf:resource="#16585209f2e440c29d9f5d0:DataActivityPurpose"/>
