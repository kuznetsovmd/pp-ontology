<owl:NamedIndividual rdf:about="#evidence281">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clear Gifs Web Beacons/Web Bugs We employ a software technology called clear gifs a k a Web Beacons/Web Bugs that help us better manage content on our site by informing us what content is effective Clear gifs are tiny graphics with a unique identifier similar in function to cookies and are used to track the online movements of Web users The main difference between the two is that clear gifs are invisible on the page and are much smaller about the size of the period at the end of this sentence Clear gifs are not tied to users? personally identifiable information</evidenceContent>
</owl:NamedIndividual>

