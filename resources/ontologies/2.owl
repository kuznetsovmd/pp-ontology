<owl:NamedIndividual rdf:about="#evidence482">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tell-A-Friend If a user elects to use our referral service for informing a friend about our site we ask them for the friend s name and email address RedOrbit Inc will automatically send the friend a one-time email inviting them to visit the site RedOrbit Inc stores this information for the sole purpose of sending this one-time email and tracking the success of our referral program The friend may contact RedOrbit Inc to request the removal of this information from our database</evidenceContent>
</owl:NamedIndividual>

