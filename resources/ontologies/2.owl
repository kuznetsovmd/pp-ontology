  <has_purpose rdf:resource="#0313321d319246ffb94ac63:DataActivityPurpose"/>
  <has_mode rdf:resource="#57879a212c164cd2beac395:DataTransmissionMode"/>
  <has_mechanism rdf:resource="#1d43f3e526904aa0873ec32:TPSaCMechanism"/>
  <applies_to rdf:resource="#7eee9902fef14dc8b4956b6:GenericData"/>
  <collects_from rdf:resource="#ed5f1f1de571424b8acfdf5:ThirdParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1bb7f55c7bb448ecb88aeea</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Business Transitions In the event RedOrbit Inc goes through a business transition such as a merger being acquired by another company or selling a portion of its assets users personal information will in most instances be part of the assets transferred Users will be notified via email prior to a change of ownership or control of their personal information If as a result of the business transition the users? personally identifiable information will be used in a manner different from that stated at the time of collection they will be given choice consistent with our notification of changes section</evidence>
</owl:NamedIndividual>

