<owl:NamedIndividual rdf:about="#84090ab318994748a04ca00:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#4711b18a432a45279186fd7:User"/>
  <has_mechanism rdf:resource="#b6f8f07b26e8490ca9b17d5:Manual"/>
  <applies_to rdf:resource="#269aa990a8ad4f289756466:GenericData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">84090ab318994748a04ca00</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Choice/Opt-out Our users are given the opportunity to opt-out of having their information used for purposes not directly related to our site at the point where we ask for information For example our order form has an opt-out mechanism so users who buy a product from us but don t want any marketing material can keep their email address off of our lists</evidence>
