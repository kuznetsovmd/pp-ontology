<owl:NamedIndividual rdf:about="#5941dff4c7904df48ceecf1:FPCollection">
  <rdf:type rdf:resource="#FPCollection"/>
  <initiated_by rdf:resource="#8bb113c52c734c5f81115fe:FirstParty"/>
  <has_mechanism rdf:resource="#e9e347efa4764c73a0c25d8:UserSpecific"/>
  <applies_to rdf:resource="#02bb997c36704243985c91f:DeviceData"/>
  <collects_from rdf:resource="#912ae4af4bf84d7ea9b2293:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">5941dff4c7904df48ceecf1</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mobile Device IDs and Location-Based Information Certain mobile devices including smart phones and tablet devices contain unique device IDs that can be used to identify their physical location Mobile devices also typically transmit caller ID data which may include a phone number when used to transmit a telephone call or text message When you use mobile devices to access our Services we may collect and transmit unique device IDs and collect caller ID data information about your wireless carrier the make model operating system and settings of your device and information about how you navigate within our Service With your consent we also may use precise geolocation technology such as GPS or Wi-Fi triangulation to collect information about the exact location of your mobile device</evidence>
</owl:NamedIndividual>

