<owl:NamedIndividual rdf:about="#45ccadd064ae4f2bb52ab71:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#ec70c501b7824335a55f5c5:User"/>
  <has_mechanism rdf:resource="#11f9afde544f417fbbb11a7:Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">45ccadd064ae4f2bb52ab71</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">You can choose to have your computer warn you each time a cookie is being sent or you can choose to turn off all cookies You do this through your browser e g Microsoft Internet Explorer Mozilla Firefox Google Chrome or Apple Safari settings Each browser is a little different so look at your browser Help menu to learn the correct way to modify your cookies If you turn cookies off you won t have access to many features that make your Site experience more efficient and some of our services will not function properly</evidence>
</owl:NamedIndividual>

