  <applies_to rdf:resource="#3353a91486094d37bd0b92a:GenericData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">83ff6b91c4ec4bef99b529f</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In order to comment on articles appearing on the Site you may only do so through Facebook by first logging onto Facebook using your Facebook user name and password Your use of the Facebook site is subject to Facebook s Statement of Rights and Responsibilities http //www facebook com/ !/legal/terms as well as Facebook s Data Use Policy http //www facebook com/about/privacy/ If you access the Site via a website such as Facebook we will have access to your profile information on such site The Post-Gazette may collect any personal information regarding our visitors from Facebook as a result of such comments posted via Facebook</evidence>
</owl:NamedIndividual>

