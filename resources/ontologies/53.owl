<owl:NamedIndividual rdf:about="#b0d77a05a5714abeaf21ac1:TPCollection">
  <rdf:type rdf:resource="#TPCollection"/>
  <initiated_by rdf:resource="#b1c73ce8279b4b8db70fd83:FirstParty"/>
  <has_purpose rdf:resource="#6a6b124f21fb48649c34891:DataActivityPurpose"/>
  <has_mechanism rdf:resource="#d7c32241fd294178a7ba292:TPSaCMechanism"/>
