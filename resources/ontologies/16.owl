<owl:NamedIndividual rdf:about="#evidence278">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Our Security Precautions Strong precautions are taken to protect the information of the users of our Site When users submit sensitive information via the Site that Information is protected both online and off-line</evidenceContent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#activity3">
  <rdf:type rdf:resource="#Activity"/>
