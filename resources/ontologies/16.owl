<owl:NamedIndividual rdf:about="#a133ea0b87da4d0fb12fce4:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#1b74b331e44f4feea6b5fd2:FirstParty"/>
  <has_mechanism rdf:resource="#209f1c7eeb2e45609c5c9d3:TechnicalMeasure"/>
