<owl:NamedIndividual rdf:about="#0f3072ab4f81400e8bfb458:Retention">
  <rdf:type rdf:resource="#Retention"/>
  <initiated_by rdf:resource="#82511cc033d14e1aa14c0ff:FirstParty"/>
  <lasts_for rdf:resource="#1f998150b2ee4e8ab5c25a8:DataRetentionTime"/>
  <has_purpose rdf:resource="#f6b747d55b904feeabb29a1:DataActivityPurpose"/>
  <applies_to rdf:resource="#4bdb8e6fc0a246559cdee31:FinancialData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0f3072ab4f81400e8bfb458</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sally Ride Science has taken steps to ensure that any information we collect is secure Our security measures include limiting the number of people who have physical access to our database and servers utilizing electronic security systems and using password protections that guard against unauthorized access We are also sensitive to security concerns regarding the use of credit cards for purchases We protect your credit card information and all other personal information using Secure Socket Layer SSL technology that automatically encrypts all data while information is being transmitted over the Internet Furthermore we will not keep your credit card number in our database once a transaction is completed</evidence>
</owl:NamedIndividual>

