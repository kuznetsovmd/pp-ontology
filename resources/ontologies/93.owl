<owl:NamedIndividual rdf:about="#0d1e07eb6bab4aef92478ad:TrackingData">
  <rdf:type rdf:resource="#TrackingData"/>
  <provided_by rdf:resource="#5d9ff69879d346ac98cc088:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0d1e07eb6bab4aef92478ad</uuid>
