<owl:NamedIndividual rdf:about="#cd9784ae0afe4d04bf52d49:PolicyChange">
  <rdf:type rdf:resource="#PolicyChange"/>
  <initiated_by rdf:resource="#5d54f4fa0b8c4f248d501b4:FirstParty"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cd9784ae0afe4d04bf52d49</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">We re updating our Privacy Policy to highlight this new collaboration but we want to make sure you understand that you still have control over who sees your photos You still get to choose who can see your Instagram photos and you still get to choose whether you post your photos on Facebook So while we re looking forward to working closely with Facebook to build better experiences we aren t changing the core features of the app that you ve come to know and love</evidence>
</owl:NamedIndividual>

