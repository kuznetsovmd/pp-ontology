<owl:NamedIndividual rdf:about="#evidence297">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">We take children s privacy very seriously and encourage parents to contact us with any questions or concerns they may have via the web form at www loc gov/contact/web-site-comments/ Additionally if parents want us to delete any collected personally identifiable information about their children under the age of 13 they can also contact us at the website address listed above</evidenceContent>
</owl:NamedIndividual>

