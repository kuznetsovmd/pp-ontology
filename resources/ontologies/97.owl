         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://privacy-ontology.com/97.owl"
         xmlns="http://privacy-ontology.com/97.owl#">

<owl:Ontology rdf:about="http://privacy-ontology.com/97.owl"/>

<owl:ObjectProperty rdf:about="#considered_by">
  <owl:inverseOf rdf:resource="#considers"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#considers">
  <owl:inverseOf rdf:resource="#considered_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#applied_by">
  <owl:inverseOf rdf:resource="#applies_to"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#applies_to">
  <owl:inverseOf rdf:resource="#applied_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#provided_by">
  <owl:inverseOf rdf:resource="#provides"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#provides">
  <owl:inverseOf rdf:resource="#provided_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#initiated_by">
  <owl:inverseOf rdf:resource="#initiates"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#initiates">
  <owl:inverseOf rdf:resource="#initiated_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#mechanism_of">
  <owl:inverseOf rdf:resource="#has_mechanism"/>
