<owl:NamedIndividual rdf:about="#57f66811a30240ecbbf8c35:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#a7539aa5fed84c548e7a5f0:FirstParty"/>
  <has_mechanism rdf:resource="#f4349b7a694a42d695b6ea5:PseudoAnonymization"/>
