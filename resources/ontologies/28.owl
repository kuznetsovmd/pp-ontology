  <has_mechanism rdf:resource="#fd636e35c9a04ca994757e1:Manual"/>
  <applies_to rdf:resource="#ff2140b5ee144116927289b:NonSensitiveData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2fde9bb84d164530b2dd176</uuid>
