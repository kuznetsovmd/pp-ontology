<owl:NamedIndividual rdf:about="#682f53e3b2454893bebeb01:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#a7539aa5fed84c548e7a5f0:FirstParty"/>
  <has_mechanism rdf:resource="#6e6aa51fa209464d81183aa:PseudoAnonymization"/>
  <applies_to rdf:resource="#d986b5a3a9344f9ba3cd2da:GenericData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">682f53e3b2454893bebeb01</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When you use Facebook Connect OpenID or another multisite ID to log in to an Online Service those ID services will authenticate your identity and provide you the option to share certain personal information with us to pre-populate our sign up form Depending on your account settings multisite IDs may also provide other information to us Please check the terms of those services before using them to log into an Online Service When you play certain software products published by the Company information about your gameplay may be collected and transmitted to the Company through network services or any other internet connection method used by the hardware on which you play such games collectively and individually your Internet Connection See What Gameplay Information Does the Company Collect? below for further details</evidence>
</owl:NamedIndividual>

