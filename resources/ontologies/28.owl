<owl:NamedIndividual rdf:about="#f5de27feca8c45c1985fbfa:UserSpecialCategory">
  <rdf:type rdf:resource="#UserSpecialCategory"/>
  <is_special_category_for rdf:resource="#8ca1211c46424f9780fb38c:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">f5de27feca8c45c1985fbfa</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Since 2005 California Civil Code Section 1798 83 permits our customers who are California residents to request certain information regarding our disclosure of personal information to third parties for their direct marketing purposes If this Privacy Policy states that any personal information may be shared with third parties for their direct marketing purposes you may send inquiries regarding our disclosure policy to Take Two Interactive Attn Internet Privacy Policy Administrator 622 Broadway New York New York 10012 privacypolicy take2games com</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#09439a6987ff4ef19971108:UserSpecialCategory">
  <rdf:type rdf:resource="#UserSpecialCategory"/>
  <is_special_category_for rdf:resource="#8ca1211c46424f9780fb38c:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">09439a6987ff4ef19971108</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TRANSFER OF YOUR INFORMATION TO THE UNITED STATES AND OTHER COUNTRIES All information collected or received by the Company in connection with the Online Services is collected in processed in or transferred to the United States of America and other countries While your information is in another jurisdiction it may be accessed by the courts law enforcement and national security authorities pursuant to the laws of those jurisdictions By using our services you expressly consent to such collection transfer and processing Backup data matchmaking data and administrative data may also be stored on media or servers located in the United States of America and other countries</evidence>
</owl:NamedIndividual>

