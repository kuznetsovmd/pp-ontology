<owl:NamedIndividual rdf:about="#7fe41e9deb664eb29d434d2:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#5827c6ffaae040dd9f6a9f7:User"/>
  <has_mechanism rdf:resource="#310cb37d71d447659f8727f:Manual"/>
