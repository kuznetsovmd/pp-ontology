<owl:ObjectProperty rdf:about="#has_basis">
  <owl:inverseOf rdf:resource="#is_basis_for"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_scope_for">
  <owl:inverseOf rdf:resource="#has_scope"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_scope">
  <owl:inverseOf rdf:resource="#is_scope_for"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_special_category_for">
  <owl:inverseOf rdf:resource="#has_special_category"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#has_special_category">
  <owl:inverseOf rdf:resource="#is_special_category_for"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#collects_from">
  <owl:inverseOf rdf:resource="#is_collected_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_collected_by">
  <owl:inverseOf rdf:resource="#collects_from"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#shares_with">
  <owl:inverseOf rdf:resource="#is_shared_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#is_shared_by">
  <owl:inverseOf rdf:resource="#shares_with"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#notifies">
  <owl:inverseOf rdf:resource="#notified_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#notified_by">
  <owl:inverseOf rdf:resource="#notifies"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#following">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <owl:inverseOf rdf:resource="#followed_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#followed_by">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#Activity"/>
  <owl:inverseOf rdf:resource="#following"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#next_is">
  <rdfs:subPropertyOf rdf:resource="#followed_by"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <owl:inverseOf rdf:resource="#previous_is"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#previous_is">
  <rdfs:subPropertyOf rdf:resource="#following"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <owl:inverseOf rdf:resource="#next_is"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#binded_to">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="#Activity"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#newer_than">
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="#PrivacyPolicy"/>
  <owl:inverseOf rdf:resource="#older_than"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#older_than">
  <owl:inverseOf rdf:resource="#newer_than"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#uuid">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#evidence">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing"/>
        <owl:Class>
          <owl:complementOf rdf:resource="#PrivacyPolicy"/>
        </owl:Class>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#policyId">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#policyUpdate">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#policyWebsite">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#PrivacyPolicy"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#does">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#Activity"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#PrivacyPolicy">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#considers"/>
      <owl:allValuesFrom>
        <owl:Class>
          <owl:unionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="#Agent"/>
            <rdf:Description rdf:about="#Activity"/>
            <rdf:Description rdf:about="#Data"/>
          </owl:unionOf>
        </owl:Class>
      </owl:allValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Activity">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#considered_by"/>
          <owl:allValuesFrom rdf:resource="#PrivacyPolicy"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_basis"/>
          <owl:allValuesFrom rdf:resource="#Basis"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_purpose"/>
          <owl:allValuesFrom rdf:resource="#Purpose"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mode"/>
          <owl:allValuesFrom rdf:resource="#Mode"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#Mechanism"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#caused_by"/>
          <owl:allValuesFrom rdf:resource="#Cause"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_consequence"/>
          <owl:allValuesFrom rdf:resource="#Consequence"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#lasts_for"/>
          <owl:allValuesFrom rdf:resource="#TimePeriod"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_scope"/>
          <owl:allValuesFrom rdf:resource="#PolicyChangeScope"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Breach">
  <rdfs:subClassOf rdf:resource="#Activity"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiated_by"/>
          <owl:allValuesFrom rdf:resource="#Criminal"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#applies_to"/>
          <owl:allValuesFrom rdf:resource="#Data"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#caused_by"/>
          <owl:allValuesFrom rdf:resource="#BreachCause"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_consequence"/>
          <owl:allValuesFrom rdf:resource="#BreachConsequence"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#DataActivity">
  <rdfs:subClassOf rdf:resource="#Activity"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiated_by"/>
          <owl:allValuesFrom rdf:resource="#FirstParty"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_purpose"/>
          <owl:allValuesFrom rdf:resource="#DataActivityPurpose"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#applies_to"/>
          <owl:allValuesFrom rdf:resource="#Data"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_basis"/>
          <owl:allValuesFrom rdf:resource="#LegalBasis"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#PolicyChange">
  <rdfs:subClassOf rdf:resource="#DataActivity"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_consequence"/>
          <owl:allValuesFrom rdf:resource="#PolicyChangeConsequence"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#caused_by"/>
          <owl:allValuesFrom rdf:resource="#PolicyChangeCause"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#lasts_for"/>
          <owl:allValuesFrom rdf:resource="#PolicyAcceptanceTime"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_scope"/>
          <owl:allValuesFrom rdf:resource="#PolicyChangeScope"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Use">
  <rdfs:subClassOf rdf:resource="#DataActivity"/>
</owl:Class>

<owl:Class rdf:about="#Protection">
  <rdfs:subClassOf rdf:resource="#DataActivity"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#has_mechanism"/>
      <owl:allValuesFrom rdf:resource="#SecurityMechanism"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#FPCollection">
  <rdfs:subClassOf rdf:resource="#DataActivity"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#collects_from"/>
          <owl:allValuesFrom rdf:resource="#User"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#UserSpecific"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mode"/>
          <owl:allValuesFrom rdf:resource="#DataTransmissionMode"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#TPCollection">
  <rdfs:subClassOf rdf:resource="#DataActivity"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#collects_from"/>
          <owl:allValuesFrom rdf:resource="#ThirdParty"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#TPSaCMechanism"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mode"/>
          <owl:allValuesFrom rdf:resource="#DataTransmissionMode"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#TPSharing">
  <rdfs:subClassOf rdf:resource="#DataActivity"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#shares_with"/>
          <owl:allValuesFrom rdf:resource="#ThirdParty"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#TPSaCMechanism"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mode"/>
          <owl:allValuesFrom rdf:resource="#DataTransmissionMode"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Retention">
  <rdfs:subClassOf rdf:resource="#DataActivity"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#DataRetentionMechanism"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#lasts_for"/>
          <owl:allValuesFrom rdf:resource="#DataRetentionTime"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Notification">
  <rdfs:subClassOf rdf:resource="#Activity"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiated_by"/>
          <owl:allValuesFrom rdf:resource="#Agent"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#notifies"/>
          <owl:allValuesFrom rdf:resource="#Agent"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#CommunicationMechanism"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#lasts_for"/>
          <owl:allValuesFrom rdf:resource="#NotificationTime"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#FPNotification">
  <rdfs:subClassOf rdf:resource="#Notification"/>
  <owl:disjointWith rdf:resource="#UserNotification"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiated_by"/>
          <owl:allValuesFrom rdf:resource="#FirstParty"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#notifies"/>
          <owl:allValuesFrom rdf:resource="#User"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#FPSpecific"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#UserNotification">
  <rdfs:subClassOf rdf:resource="#Notification"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiated_by"/>
          <owl:allValuesFrom rdf:resource="#User"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#notifies"/>
          <owl:allValuesFrom rdf:resource="#FirstParty"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#Manual"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#DataControl">
  <rdfs:subClassOf rdf:resource="#Activity"/>
  <owl:disjointWith rdf:resource="#PolicyChange"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiated_by"/>
          <owl:allValuesFrom rdf:resource="#User"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#applies_to"/>
          <owl:allValuesFrom rdf:resource="#Data"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_basis"/>
          <owl:allValuesFrom rdf:resource="#LegalBasis"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_mechanism"/>
          <owl:allValuesFrom rdf:resource="#Manual"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#ProvidedDataControl">
  <rdfs:subClassOf rdf:resource="#DataControl"/>
</owl:Class>

<owl:Class rdf:about="#PrivacyControl">
  <rdfs:subClassOf rdf:resource="#DataControl"/>
</owl:Class>

<owl:Class rdf:about="#OptControl">
  <rdfs:subClassOf rdf:resource="#DataControl"/>
</owl:Class>

<owl:Class rdf:about="#Agent">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#considered_by"/>
          <owl:allValuesFrom rdf:resource="#PrivacyPolicy"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiates"/>
          <owl:allValuesFrom rdf:resource="#Activity"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#User">
  <rdfs:subClassOf rdf:resource="#Agent"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#provides"/>
          <owl:allValuesFrom rdf:resource="#Data"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiates"/>
          <owl:allValuesFrom>
            <owl:Class>
              <owl:unionOf rdf:parseType="Collection">
                <rdf:Description rdf:about="#DataControl"/>
                <rdf:Description rdf:about="#UserNotification"/>
              </owl:unionOf>
            </owl:Class>
          </owl:allValuesFrom>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#has_special_category"/>
          <owl:allValuesFrom rdf:resource="#UserSpecialCategory"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#is_collected_by"/>
          <owl:allValuesFrom rdf:resource="#FPCollection"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#notified_by"/>
          <owl:allValuesFrom rdf:resource="#FPNotification"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#FirstParty">
  <rdfs:subClassOf rdf:resource="#Agent"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <owl:Restriction>
          <owl:onProperty rdf:resource="#initiates"/>
          <owl:allValuesFrom>
            <owl:Class>
              <owl:unionOf rdf:parseType="Collection">
                <rdf:Description rdf:about="#DataActivity"/>
                <rdf:Description rdf:about="#FPNotification"/>
              </owl:unionOf>
            </owl:Class>
          </owl:allValuesFrom>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#notified_by"/>
          <owl:allValuesFrom rdf:resource="#UserNotification"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#ThirdParty">
