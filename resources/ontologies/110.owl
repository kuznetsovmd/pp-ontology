<owl:NamedIndividual rdf:about="#ddc13c48abdc4cf88195aa4:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#eacab63aa2a44c07b079128:FirstParty"/>
  <has_mechanism rdf:resource="#b305ed8a1e9844b7bd854e6:PseudoAnonymization"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ddc13c48abdc4cf88195aa4</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Our service providers have access to your personally identifiable information as necessary to provide certain services on our behalf They are required to maintain the privacy of all such information in their possession or control and can only use the information on our behalf for the purpose that we have contracted them for example processing your order or sending you a series newsletter They are not authorized to use your information for any other purpose</evidence>
</owl:NamedIndividual>

