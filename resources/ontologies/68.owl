<owl:NamedIndividual rdf:about="#0fe899d33eca439c815faa8:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#89e89a2b897a497e95df7cf:FirstParty"/>
  <has_mechanism rdf:resource="#ffaa71d761e74e47a399e48:PseudoAnonymization"/>
  <applies_to rdf:resource="#841b93c53ddb42c8ba16fd1:GenericData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0fe899d33eca439c815faa8</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Privacy Policy Posted Tuesday September 18 2012 12 29 pm Updated Thursday May 21 2015 3 22 pm Our commitment to you The Frederick News-Post and its owner Randall Family LLC collectively The News-Post recognize the importance of protecting the privacy of personally identifiable information collected about you our customers This customer privacy policy is intended to outline our legitimate business interests in collecting and using information and your reasonable expectations of privacy</evidence>
</owl:NamedIndividual>

