  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Most importantly, any recorded IP addresses are not linked to personally identifiable information.</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#543af67236b7463aab60cad:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#81413de1c061406897c13e2:FirstParty"/>
  <has_mechanism rdf:resource="#3098e7c732e5417cbd49a29:PseudoAnonymization"/>
