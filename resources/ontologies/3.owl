  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">d4ec6e53ff764600943e7f6</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If you have questions concerning our information practices with respect to children or if you would like to review have deleted or stop the further collection of your child s personal information you may contact us</evidence>
</owl:NamedIndividual>

