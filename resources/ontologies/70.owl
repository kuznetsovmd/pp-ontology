  <rdf:type rdf:resource="#DataActivityPurpose"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bbd86919e65142a09cf0b66</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">or share it with others so that we may obtain payment for your health care services. These include your health insurance company, employer-sponsored self-funded group health plan, Medicare, Medicaid, and any other party that may be responsible for paying or processing for payment of any portion your bill for services.</evidence>
</owl:NamedIndividual>

