<owl:NamedIndividual rdf:about="#79d8181b75fd416199d472e:Manual">
  <rdf:type rdf:resource="#Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">79d8181b75fd416199d472e</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">How To Obtain A Copy Of This Notice You have the right to a paper copy of this notice You may request a paper copy at any time even if you have previously agreed to receive this notice electronically To do so please call the Kaleida Health Privacy Officer at 716-859-8559 You may also obtain a copy of this notice from our website at www Kaleidahealth org or by requesting a copy at your next visit</evidence>
</owl:NamedIndividual>

