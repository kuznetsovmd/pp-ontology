<owl:NamedIndividual rdf:about="#30c608a8a5fb4140becb712:NonSensitiveData">
  <rdf:type rdf:resource="#NonSensitiveData"/>
  <provided_by rdf:resource="#c259e3c4dc564b7b83c844c:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">30c608a8a5fb4140becb712</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">YOUR RIGHTS TO ACCESS AND CONTROL YOUR HEALTH INFORMATION Kaleida Health wants you to know that you have the following rights to access and control your health information These rights are important because they will help you make sure that the health information we have about you is accurate They may also help you control the way Kaleida Health uses your information and share it with others or the way we communicate with you about your medical matters</evidence>
</owl:NamedIndividual>

