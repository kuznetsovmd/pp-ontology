<owl:NamedIndividual rdf:about="#ed5a13344fb74049aebf36e:Manual">
  <rdf:type rdf:resource="#Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ed5a13344fb74049aebf36e</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">You have the right to request that we communicate with you about your medical matters in a more confidential way by requesting that Kaleida Health communicates with you by alternative means or at alternative locations. For example, you may ask that we contact you at home instead of at work.</evidence>
</owl:NamedIndividual>

