<owl:NamedIndividual rdf:about="#d9423f1a7f5440c281a560e:TPSaCMechanism">
  <rdf:type rdf:resource="#TPSaCMechanism"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">d9423f1a7f5440c281a560e</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if you choose to participate in any loyalty program in which Hat World participates, such as LIDS Club, and you authorize Hat World to provide information about purchases you make to the company administering the program, we will share personal information about you with that company.</evidence>
</owl:NamedIndividual>

