</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#f46be96960d94a018c82f24:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#5a374520668d449e8b72953:FirstParty"/>
  <has_mechanism rdf:resource="#e9a8d8f189fa43a781193cf:PseudoAnonymization"/>
