</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#92778da0969a41fdb751376:UserSpecialCategory">
  <rdf:type rdf:resource="#UserSpecialCategory"/>
  <is_special_category_for rdf:resource="#34a0ef293dd74ee586184cf:User"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">92778da0969a41fdb751376</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">To carry this promise through we do not sell products for purchase by children We sell children s products for purchase by adults If you are under 18 you may use the Sites only with involvement of a parent or guardian</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#933fa7e246ac4eaca555060:UserSpecialCategory">
  <rdf:type rdf:resource="#UserSpecialCategory"/>
