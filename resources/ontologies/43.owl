</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#6fef29b502af49d5aa28536:Encryption">
  <rdf:type rdf:resource="#Encryption"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">6fef29b502af49d5aa28536</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">We work to protect the security of your information during transmission by using Thawte Certified Secure Sockets Layer SSL software which encrypts information you input We reveal only the last four digits of your credit card numbers when confirming an order Of course we transmit the entire credit card number to the appropriate credit card company during order processing</evidence>
</owl:NamedIndividual>

