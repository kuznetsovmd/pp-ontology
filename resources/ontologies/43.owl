<owl:NamedIndividual rdf:about="#5cce47717c9e42958181055:TechnicalMeasure">
  <rdf:type rdf:resource="#TechnicalMeasure"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">5cce47717c9e42958181055</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">How does Hat World keep your information secure- Hat World is always striving to ensure you a safe and convenient online experience This goes beyond our technologies to include physical contractual and managerial safeguards to protect your personal information</evidence>
</owl:NamedIndividual>

