<owl:NamedIndividual rdf:about="#173ad49f94e9494cad670db:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#34a0ef293dd74ee586184cf:User"/>
