  <rdf:type rdf:resource="#Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">5367ada8c13440d9a5bbeb6</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Many ad companies are members of the Network Advertising Initiative. NAI members allow users to opt out of being tracked by cookies. To opt out of cookie tracking by NAI members, you may visit http://www.networkadvertising.org/ and click on the "Consumer Opt-out" button. Companies may also be members of the Digital Advertising Alliance ("DAA") and to opt out of cookie tracking by DAA members, you may visit http://www.aboutads.info/choices/.</evidence>
</owl:NamedIndividual>

