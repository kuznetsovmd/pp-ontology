<owl:NamedIndividual rdf:about="#cb5b72d7a4f44a1fa990e41:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#04c071c8a588470895d4232:User"/>
  <has_mechanism rdf:resource="#2183045239914b818323c13:Manual"/>
  <applies_to rdf:resource="#8b807fecd3ff4dac900e615:TrackingData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cb5b72d7a4f44a1fa990e41</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Many ad companies are members of the Network Advertising Initiative NAI members allow users to opt out of being tracked by cookies To opt out of cookie tracking by NAI members you may visit http //www networkadvertising org/ and click on the Consumer Opt-out button Companies may also be members of the Digital Advertising Alliance DAA and to opt out of cookie tracking by DAA members you may visit http //www aboutads info/choices/ Finally to learn how to remove cookies you may visit these links deleting cookies and deleting flash cookies By using our site and products you give us explicit consent to place cookies and other tracking technology on your computer or mobile device</evidence>
</owl:NamedIndividual>

