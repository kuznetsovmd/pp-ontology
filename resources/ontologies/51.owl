<owl:Ontology rdf:about="http://privacy-ontology.com/51.owl"/>

<owl:ObjectProperty rdf:about="#considered_by">
  <owl:inverseOf rdf:resource="#considers"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#considers">
  <owl:inverseOf rdf:resource="#considered_by"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#applied_by">
  <owl:inverseOf rdf:resource="#applies_to"/>
</owl:ObjectProperty>

