<owl:NamedIndividual rdf:about="#701d47cd547a442094a8401:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#26d4a3dfdefd40599cd939a:FirstParty"/>
  <has_mechanism rdf:resource="#602e136fc4644f5ca573c5a:PseudoAnonymization"/>
