<owl:NamedIndividual rdf:about="#997c08f8f7ea4b4fb2f1caa:Retention">
  <rdf:type rdf:resource="#Retention"/>
  <initiated_by rdf:resource="#26d4a3dfdefd40599cd939a:FirstParty"/>
  <lasts_for rdf:resource="#64e739746f784c1d84d617c:DataRetentionTime"/>
  <has_purpose rdf:resource="#4a906b325d4444a6a08d146:DataActivityPurpose"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">997c08f8f7ea4b4fb2f1caa</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Retention of Personal Information We will retain your personal information while you have an account with us and thereafter for as long as we need it for purposes not prohibited by applicable laws Thereafter we will either delete your personal information or de-identify it so that it is anonymous and not attributed to your identity Your rights to request that we delete your personal information are set forth in the Accessing Correcting and Deleting Your Personal Information section above</evidence>
</owl:NamedIndividual>

