<owl:NamedIndividual rdf:about="#158e3b3ef00c43cc8eecced:Protection">
  <rdf:type rdf:resource="#Protection"/>
  <initiated_by rdf:resource="#26d4a3dfdefd40599cd939a:FirstParty"/>
  <has_mechanism rdf:resource="#e9db019efb0d4f8e90dd874:PseudoAnonymization"/>
  <applies_to rdf:resource="#442ea0d427bf4b73a4d8e5f:TrackingData"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">158e3b3ef00c43cc8eecced</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Web Beacons Our websites may also use small pieces of code called web beacons or clear gifs to collect anonymous and aggregate advertising metrics such as counting page views promotion views or advertising responses A web beacon is an electronic image called a single-pixel or clear GIF Web beacons can recognize certain types of information such as a user s cookie number time and date of a page view and description of the page where the web beacon is placed These web beacons may be used to deliver cookies that conform to our cookie policy above</evidence>
</owl:NamedIndividual>

