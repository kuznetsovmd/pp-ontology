<owl:NamedIndividual rdf:about="#evidence236">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Your California Privacy Rights If you live in California and have an established business relationship with us you can request a list of the personal information we have shared with third parties for their marketing purposes We will also give you a list of the third parties that have received your information You can make a request one time each year</evidenceContent>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#userspecialcategory3">
