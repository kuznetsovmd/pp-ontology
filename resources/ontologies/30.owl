  <hasEvidence rdf:resource="#evidence237"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#evidence237">
  <rdf:type rdf:resource="#Evidence"/>
  <evidenceContent rdf:datatype="http://www.w3.org/2001/XMLSchema#string">To exercise your rights you can email us or write to us at the address below Mention in your letter that you are making a California Shine the Light inquiry We will respond within 30 days</evidenceContent>
</owl:NamedIndividual>

