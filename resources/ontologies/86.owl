<owl:NamedIndividual rdf:about="#b0a96f7a1d814512a5b1dcf:ProvidedDataControl">
  <rdf:type rdf:resource="#ProvidedDataControl"/>
  <initiated_by rdf:resource="#e7f35d11f7b14ce8b606679:User"/>
  <has_mechanism rdf:resource="#073c220e1c414df48519996:Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">b0a96f7a1d814512a5b1dcf</uuid>
  <does rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</does>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Use of Cookies A cookie is a piece of information that our web sites send to your browser which then is stored on your system A user can use our web sites without cookies however our systems need cookies for premium content in order to identify you as a premium subscriber You may disable or delete the cookies at any time Many users prefer to use cookies in order to help them navigate a Web site as seamlessly as possible You should be aware that cookies contain no more information than you volunteer and they are not able to invade your hard drive and return to the sender any personal or other information from your computer</evidence>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#4990f34ec3404e58b456127:TrackingData">
