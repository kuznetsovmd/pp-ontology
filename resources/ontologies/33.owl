<owl:NamedIndividual rdf:about="#de50414356434e9f914518a:Manual">
  <rdf:type rdf:resource="#Manual"/>
  <uuid rdf:datatype="http://www.w3.org/2001/XMLSchema#string">de50414356434e9f914518a</uuid>
  <evidence rdf:datatype="http://www.w3.org/2001/XMLSchema#string">By accessing any part of the Sites or using the Services, you agree to the practices described in this Policy and consent to the collection, use and disclosure of your personal information as set out in this Policy. This Policy is part of the Terms of Use governing your use of the Sites and the Services; please read the Terms of Use. If you do not wish to provide your consent and/or do not agree with any part of this Policy and/or the Terms of Use, please do not use the Sites or the Services.</evidence>
</owl:NamedIndividual>

